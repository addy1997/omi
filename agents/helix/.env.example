# ── LLM providers (set at least one) ────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Model selection per agent role ──────────────────────────
OMI_SUPERVISOR_MODEL=anthropic/claude-sonnet-4-5
OMI_CODER_MODEL=anthropic/claude-sonnet-4-5
OMI_EXPLORER_MODEL=anthropic/claude-haiku-4-5
OMI_PLANNER_MODEL=anthropic/claude-sonnet-4-5
OMI_RESEARCHER_MODEL=anthropic/claude-haiku-4-5
OMI_TRIAGER_MODEL=anthropic/claude-haiku-4-5

# ── GitHub ───────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-github-username

# ── Repos ────────────────────────────────────────────────────
OMI_REPOS_DIR=/tmp/omi/repos
OMI_WORKTREES_DIR=/tmp/omi/worktrees

# ── Storage ─────────────────────────────────────────────────
OMI_DB_URL=sqlite+aiosqlite:///./omi.db

# ── Sandbox ─────────────────────────────────────────────────
OMI_SANDBOX=subprocess
OMI_SHELL_TIMEOUT=120

# ── API ──────────────────────────────────────────────────────
OMI_HOST=0.0.0.0
OMI_PORT=8000
OMI_SECRET_KEY=change-me-in-production
