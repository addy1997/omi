# ═══════════════════════════════════════════════════════════
# Omi Platform — Environment Configuration
# DO NOT COMMIT REAL VALUES. Copy to .env and customize.
# ═══════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────
PLATFORM_HOST=0.0.0.0
PLATFORM_PORT=9000
PLATFORM_ENVIRONMENT=development
PLATFORM_DEBUG=false

# ── Security (CHANGE IN PRODUCTION) ──────────────────────────
PLATFORM_SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production
PLATFORM_JWT_ALGORITHM=HS256
PLATFORM_JWT_EXPIRATION_HOURS=24

# ── Database ─────────────────────────────────────────────────
PLATFORM_DB_URL=sqlite+aiosqlite:///./platform.db
# Production: postgresql://user:password@host:5432/omi

# ── Frontend (CORS) ──────────────────────────────────────────
PLATFORM_DASHBOARD_URL=http://localhost:5173
# Production: https://yourdomain.com

# ── LLM Routing (for task routing) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
PLATFORM_ROUTER_MODEL=anthropic/claude-haiku-4-5

# ── Agent Registry ───────────────────────────────────────────
PLATFORM_AGENT_HEARTBEAT_INTERVAL=30
PLATFORM_AGENT_STALE_TIMEOUT=180

# ── Sandbox ───────────────────────────────────────────────────
PLATFORM_SANDBOX=docker
# docker = secure sandbox (recommended)
# subprocess = direct execution (dev only)

# ── Logging & Observability ──────────────────────────────────
PLATFORM_LOG_LEVEL=INFO
PLATFORM_ENABLE_LOGGING=true
