graph TB
    User["👤 User"]

    subgraph Client["Client Layer"]
        Dashboard["React Dashboard<br/>(localhost:5173)<br/>Chat • Agents • Tasks • Metrics"]
    end

    User -->|HTTP/WebSocket| Dashboard

    subgraph Network["Network Communication"]
        HTTP["HTTP REST API<br/>WebSocket Streaming"]
    end

    Dashboard -->|HTTP/WS| HTTP
    HTTP -->|HTTP/WS| API

    subgraph Platform["Omi Platform API (localhost:9000)"]
        APIGateway["API Gateway<br/>FastAPI + CORS"]

        subgraph Routing["Task Routing"]
            KeywordRouter["Keyword<br/>Heuristics"]
            LLMRouter["LLM Router<br/>Claude Haiku"]
        end

        subgraph Management["Agent Management"]
            Registry["Agent Registry<br/>Health Monitoring<br/>Heartbeat Tracking"]
            Dispatcher["Task Dispatcher<br/>Queue & Executor"]
        end

        subgraph Storage["Persistence"]
            TaskDB["Task History<br/>Sessions<br/>SQLite/PostgreSQL"]
        end

        subgraph Observability["Observability"]
            Tracker["Usage Tracker<br/>Tokens • Costs<br/>Performance Metrics"]
        end

        APIGateway --> KeywordRouter
        APIGateway --> LLMRouter
        APIGateway --> Registry
        APIGateway --> Dispatcher
        APIGateway --> TaskDB
        APIGateway --> Tracker
        KeywordRouter --> Dispatcher
        LLMRouter --> Dispatcher
        Dispatcher --> Registry
        Registry --> Tracker
        Dispatcher --> TaskDB
    end

    subgraph Agents["Agent Layer"]
        subgraph Helix["Helix (Coding Agent)<br/>Port 8000"]
            HelixSupervisor["LangGraph Supervisor<br/>ReAct Loop"]
            CoderAgent["Coder Agent"]
            ExplorerAgent1["Explorer Agent"]
            HelixSupervisor --> CoderAgent
            HelixSupervisor --> ExplorerAgent1
        end

        subgraph HelixTools["Helix Tools"]
            CodeTools["File I/O • Git<br/>GitHub API • Shell"]
            AST["Tree-sitter AST<br/>Symbol Search"]
            CodeTools -.-> AST
        end

        subgraph Other["Other Agents"]
            PlannerAgent["Planner<br/>Decomposition"]
            ResearcherAgent["Researcher<br/>Web Search"]
            TriagerAgent["Triager<br/>Issue Labels"]
        end

        CoderAgent --> CodeTools
        ExplorerAgent1 --> CodeTools
    end

    subgraph External["External Services"]
        GitHub["GitHub API<br/>Code Hosting"]
        DuckDuckGo["DuckDuckGo<br/>Web Search"]
        Ollama["Ollama/LLM<br/>Local or Cloud"]
    end

    CodeTools -->|Git Push| GitHub
    ResearcherAgent -->|Search| DuckDuckGo
    HelixSupervisor -->|Inference| Ollama
    LLMRouter -->|Routing Decision| Ollama

    API -->|Agent Registration<br/>Task /run| Dispatcher
    Dispatcher -->|Route Task| HelixSupervisor
    Dispatcher -->|Route Task| PlannerAgent
    Dispatcher -->|Route Task| ResearcherAgent
    Dispatcher -->|Route Task| TriagerAgent

    HelixSupervisor -->|Result| Dispatcher
    PlannerAgent -->|Result| Dispatcher
    ResearcherAgent -->|Result| Dispatcher
    TriagerAgent -->|Result| Dispatcher

    Dispatcher -->|Store| TaskDB
    Dispatcher -->|Track| Tracker

